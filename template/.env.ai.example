# saascon — AI provider config (Groq Cloud)
#
# This file documents the env vars for AI features (chat, voice, vision).
# All models are served by Groq Cloud — fast, OpenAI-compatible inference.
#
# Copy/merge these into your `.env`:
#
#   cat .env.ai.example >> .env
#
# Then fill in GROQ_CLOUD_API_KEY. The model IDs below are verified-working
# defaults — override only if you have a specific reason.
#
# `.env` is gitignored — never committed.
#
# Note: Groq does NOT offer image generation. The image model below is for
# image *understanding* (vision input → text output), not text-to-image.

# ─────────────────────────────────────────────────────────────────────
# Required — Groq API key
# ─────────────────────────────────────────────────────────────────────
# Get a key at https://console.groq.com/keys
# Free tier is sufficient for development (see rate limits per model).

GROQ_CLOUD_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Chat / text completion
# ─────────────────────────────────────────────────────────────────────
# Endpoint: POST https://api.groq.com/openai/v1/chat/completions
#
# openai/gpt-oss-120b — OpenAI's open-weights reasoning model. 131K context.
# Free-tier limits: 30 RPM, 1K RPD, 8K TPM, 200K TPD.
#
# IMPORTANT: this is a reasoning model. It spends tokens on internal
# `reasoning` before emitting visible `content`. Set max_tokens ≥ 200
# for short replies, or content may come back empty.

GROQ_CHAT_MODEL=openai/gpt-oss-120b

# ─────────────────────────────────────────────────────────────────────
# Voice — speech-to-text
# ─────────────────────────────────────────────────────────────────────
# Endpoint: POST https://api.groq.com/openai/v1/audio/transcriptions
# Send as multipart/form-data with `file=@path.wav` and `model=...`.
#
# whisper-large-v3-turbo — faster + cheaper than whisper-large-v3 with
# near-equal accuracy.
# Free-tier limits: 20 RPM, 2K RPD, 7.2K ASH (audio seconds/hour), 28.8K ASD.

GROQ_VOICE_MODEL=whisper-large-v3-turbo

# ─────────────────────────────────────────────────────────────────────
# Image — vision input (image → text)
# ─────────────────────────────────────────────────────────────────────
# Endpoint: POST https://api.groq.com/openai/v1/chat/completions
# Send messages with content blocks: [{type:"text"}, {type:"image_url"}].
# image_url accepts public URLs or base64 data URLs (data:image/png;base64,...).
#
# meta-llama/llama-4-scout-17b-16e-instruct — Meta's multimodal Llama 4.
# 131K context. The only vision-capable model on Groq.
# Free-tier limits: 30 RPM, 1K RPD, 30K TPM, 500K TPD.

GROQ_IMAGE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
