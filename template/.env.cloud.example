# calorie-tracker — cloud mode (Supabase + Vercel)
#
# Use this when you want to run the app against a Supabase project and
# deploy to Vercel. Pair with .env.local.example if you also want a
# local SQLite-mode template alongside it.
#
# Copy this to `.env` and fill in the bracketed values:
#
#   cp .env.cloud.example .env
#
# `.env` is gitignored — never committed.

# ─────────────────────────────────────────────────────────────────────
# Required at runtime — Supabase
# ─────────────────────────────────────────────────────────────────────
# Found in Supabase dashboard → Project Settings → API.
# - URL is the "Project URL"
# - ANON_KEY is the "anon public" key (safe in browser bundles)
# - SERVICE_ROLE_KEY is the "service_role" key (server-only — never
#   reaches the browser; never put it in NEXT_PUBLIC_*)

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-jwt>
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>

# IANA timezone for the today/history boundary. Cloud mode reads this
# on the server when computing day boundaries; the browser's TZ does
# not factor in. Defaults to "UTC" when unset.
#
# Examples: Asia/Manila, America/Los_Angeles, Europe/London, UTC
NEXT_PUBLIC_TIMEZONE=Asia/Manila


# ─────────────────────────────────────────────────────────────────────
# Required only for running migrations programmatically — Postgres
# ─────────────────────────────────────────────────────────────────────
# Not read by the running app — used only when applying schema changes
# from a Node script (or `psql`) instead of pasting SQL into the
# Supabase SQL Editor.
#
# Found in Supabase dashboard → Project Settings → Database →
# Connection string → URI tab → "Session pooler".
#
# The dashboard's "Copy" button gives you the URI with [PROJECT_REF]
# and [REGION] already filled in. Replace [YOUR-PASSWORD] with the DB
# password you set when creating the project (resettable in the same
# screen via "Reset database password").

DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres


# ─────────────────────────────────────────────────────────────────────
# Optional — Vercel CLI credentials
# ─────────────────────────────────────────────────────────────────────
# Only needed if you deploy via `vercel` CLI instead of the Vercel
# dashboard's GitHub integration. The dashboard route (Add New →
# Project → Import GitHub repo) does not need any of these.

# https://vercel.com/account/tokens
VERCEL_TOKEN=<personal-access-token>

# Vercel dashboard → your team → Settings → General → Team ID
VERCEL_ORG_ID=team_<id>

# Project → Settings → General → Project ID
VERCEL_PROJECT_ID=prj_<id>


# ─────────────────────────────────────────────────────────────────────
# Notes
# ─────────────────────────────────────────────────────────────────────
# - To run locally against this cloud DB:
#     npm run dev
#   (the router auto-picks Supabase when NEXT_PUBLIC_SUPABASE_URL is set)
#
# - To force local SQLite mode despite these vars being set:
#     SAASCON_DB_DRIVER=sqlite npm run dev
#
# - Before the app boots green against this DB, you must apply the
#   schema migrations to your Supabase project. See:
#     template/docs/deploy-vercel.md
