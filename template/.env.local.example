# calorie-tracker — environment variables
#
# This file documents every variable the app reads. Copy to `.env` and
# fill in the values you need:
#
#   cp .env.local.example .env
#
# `.env` is gitignored — never committed.
#
# The router in src/lib/db/queries.ts auto-detects which backend to use:
#   - if NEXT_PUBLIC_SUPABASE_URL is set → cloud mode (Supabase)
#   - otherwise → local SQLite mode
#
# Set SAASCON_DB_DRIVER to force a specific backend regardless.

# ─────────────────────────────────────────────────────────────────────
# Local SQLite mode (default — for `npm run dev` on your machine)
# ─────────────────────────────────────────────────────────────────────

# Force SQLite even if Supabase vars are set. Optional.
# SAASCON_DB_DRIVER=sqlite

# Path to the SQLite file. Defaults to ./local.db. Optional.
# SAASCON_SQLITE_PATH=./local.db


# ─────────────────────────────────────────────────────────────────────
# Cloud Supabase mode (for Vercel preview / production deploys)
# ─────────────────────────────────────────────────────────────────────

# Found in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key-jwt>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-jwt>

# IANA timezone for the today/history boundary in cloud mode. Defaults
# to "UTC" if unset. Local mode ignores this (uses server-local TZ).
NEXT_PUBLIC_TIMEZONE=Asia/Manila


# ─────────────────────────────────────────────────────────────────────
# Postgres connection string (only needed for running migrations
# programmatically against Supabase — not used at runtime by the app)
# ─────────────────────────────────────────────────────────────────────

# Found in Supabase dashboard → Project Settings → Database → Connection string → URI
# Use the "Session pooler" form. Replace [YOUR-PASSWORD] with the DB password
# you set when creating the project (resettable in the same screen).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres


# ─────────────────────────────────────────────────────────────────────
# Vercel CLI credentials (optional — only if deploying via `vercel` CLI
# instead of the dashboard)
# ─────────────────────────────────────────────────────────────────────

# Found at https://vercel.com/account/tokens
VERCEL_TOKEN=<personal-access-token>

# Found in Vercel dashboard → your team → Settings → General → Team ID
VERCEL_ORG_ID=team_<id>

# Found in your project → Settings → General → Project ID
VERCEL_PROJECT_ID=prj_<id>
