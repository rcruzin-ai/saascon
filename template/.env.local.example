# saascon — local SQLite mode
#
# This file documents the env vars for running entirely off a local
# SQLite file. No Supabase, no Vercel, no network. Use this when you
# want zero external dependencies for development.
#
# Copy this to `.env`:
#
#   cp .env.local.example .env
#
# Then run:
#
#   npm install
#   npm run dev
#
# `.env` is gitignored — never committed.
#
# To deploy to Vercel, switch to cloud mode by copying .env.cloud.example
# over .env instead. The router in src/lib/db/index.ts auto-detects which
# backend to use based on whether NEXT_PUBLIC_SUPABASE_URL is set.

# ─────────────────────────────────────────────────────────────────────
# Optional — both vars below have sensible defaults
# ─────────────────────────────────────────────────────────────────────

# Force SQLite even if Supabase vars happen to be set in your shell.
# Defaults to auto-detect (sqlite when NEXT_PUBLIC_SUPABASE_URL is unset).
SAASCON_DB_DRIVER=sqlite

# Path to the SQLite file. Defaults to ./local.db relative to the
# template/ directory.
SAASCON_SQLITE_PATH=./local.db
