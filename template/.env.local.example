# Local-only mode — zero external services.
# Copy this to `.env` (overwriting the Supabase one) to run saascon entirely
# off a local SQLite file. No Supabase, no Vercel, no network.
#
# Then run:
#   npm install
#   npm run db:init
#   npm run dev
#
# To switch back to cloud mode: copy `.env.example` over `.env`.

SAASCON_DB_DRIVER=sqlite
SAASCON_SQLITE_PATH=./local.db
